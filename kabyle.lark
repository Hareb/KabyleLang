// ============================================================
// kabyle.lark — Grammaire EBNF du Langage Kabyle v1.0
// ============================================================
// Auteur  : Lounes Hareb
// Projet  : KabyleLang — Premier langage de programmation en kabyle
//
// Utilise la syntaxe Lark (EBNF étendue) avec gestion
// de l'indentation via l'Indenter intégré de Lark.
//
// CONVENTIONS :
//   - Règles en MAJUSCULES = terminaux (tokens)
//   - Règles en minuscules  = règles de production
//   - Terminaux avec préfixe _ (ex: _MA) = tokens écartés de
//     l'arbre (consommés pour la structure uniquement)
//   - Règles avec préfixe ? (ex: ?expr) = passthrough si un
//     seul enfant (évite les nœuds inutiles dans l'arbre)
//   - Instructions séparées par _NEWLINE
//   - Blocs délimités par _INDENT / _DEDENT
// ============================================================

// ─── POINT D'ENTRÉE ────────────────────────────────────────
// Un programme = suite d'instructions au niveau supérieur
start: (_NEWLINE | statement)*

// ─── INSTRUCTIONS (STATEMENTS) ─────────────────────────────
statement: simple_stmt | compound_stmt

// Instructions simples (une seule ligne)
simple_stmt: (global_stmt
            | import_stmt
            | return_stmt
            | assign_stmt
            | subscript_assign_stmt
            | break_stmt
            | continue_stmt
            | expr_stmt) _NEWLINE

// Instructions composées (avec bloc indenté)
compound_stmt: if_stmt
             | while_stmt
             | for_stmt
             | funcdef
             | try_stmt

// ─── IMPORT  (awid) ────────────────────────────────────────
// awid math          → import math
// awid math deg sin  → from math import sin
import_stmt: _AWID NAME (_DEG NAME ("," NAME)*)?

// ─── DÉFINITION DE FONCTION  (bnu) ─────────────────────────
// bnu nom(param1, param2):
//     corps
funcdef: _BNU NAME "(" [parameters] ")" ":" block

// Liste de paramètres (noms séparés par des virgules)
parameters: NAME ("," NAME)*

// ─── RETOUR DE VALEUR  (erred) ──────────────────────────────
return_stmt: _ERRED [expr]

// ─── ASSIGNATION ────────────────────────────────────────────
// x = 10   |   x += 5   |   x -= 1
assign_stmt: NAME assign_op expr

assign_op: "="  -> assign
         | "+=" -> iadd
         | "-=" -> isub
         | "*=" -> imul
         | "/=" -> idiv

// ─── ASSIGNATION PAR INDEX ───────────────────────────────────
// d["key"] = value | l[0] = value
subscript_assign_stmt: NAME "[" expr "]" "=" expr

// ─── INSTRUCTION EXPRESSION  (appel de fonction seul) ──────
// Permet d'utiliser une expression seule sur une ligne,
// typiquement un appel comme aru("bonjour").
expr_stmt: expr

// ─── GLOBAL (umata) ─────────────────────────────────────────
global_stmt: _UMATA NAME ("," NAME)*

// ─── CONDITION  (ma / ma_ulac) ──────────────────────────────
// ma condition:
//     bloc_vrai
// ma_ulac:           ← optionnel
//     bloc_faux

if_stmt: _MA expr ":" block (_MA_YELLA expr ":" block)* (_MA_ULAC ":" block)?

// ─── BOUCLE WHILE  (skud) ───────────────────────────────────
while_stmt: _SKUD expr ":" block

// ─── BOUCLE FOR  (yal ... deg ...) ──────────────────────────
// yal i deg range(5):
//     corps
for_stmt: _YAL NAME _DEG expr ":" block

// ─── BREAK / CONTINUE ────────────────────────────────────────
break_stmt: _HBES
continue_stmt: _KEMMEL

// ─── TRY / EXCEPT ────────────────────────────────────────────
try_stmt: _JERREB ":" block _SLEK ":" block

// ─── BLOC (groupe d'instructions indentées) ─────────────────
// Délimité par INDENT … DEDENT injectés par KabyleIndenter.
block: _NEWLINE _INDENT statement+ _DEDENT

// ============================================================
// EXPRESSIONS
// ============================================================
// Hiérarchie de priorité (faible → fort) :
//   or > and > not > comparison > + - > * / > unaire > ** > atome
//
// Le préfixe '?' permet à Lark d'inliner la règle si elle n'a
// qu'un seul enfant (évite la création de nœuds inutiles).

?expr: or_expr

?or_expr: and_expr (NEGH and_expr)*

?and_expr: not_expr (AKKED not_expr)*

// 'not_expr' n'est inliné que si c'est une simple comparison.
// Pour "macci X", on crée un vrai nœud (2 enfants → pas de passthrough).
?not_expr: MACCI not_expr
         | comparison

?comparison: arith_expr (comp_op arith_expr)*

comp_op: "==" -> eq
       | "!=" -> ne
       | "<=" -> le
       | ">=" -> ge
       | "<"  -> lt
       | ">"  -> gt

?arith_expr: term ((PLUS | MINUS) term)*

?term: factor ((STAR | SLASH | PERCENT | DOUBLESLASH) factor)*

?factor: PLUS factor  -> uplus
       | MINUS factor -> uminus
       | power

?power: atom ("**" factor)?

// ─── ATOMES (valeurs de base) ────────────────────────────────
?atom: NUMBER           -> number
     | STRING           -> string
     | FSTRING          -> fstring
     | list_literal
     | dict_literal
     | "(" expr ")"     -> paren_expr
     | attr_call
     | subscript
     | call_expr
     | IH               -> true_val
     | ALA              -> false_val
     | NAME             -> var

list_literal: "[" [expr ("," expr)*] "]"
dict_literal: "{" [dict_pair ("," dict_pair)*] "}"
dict_pair: expr ":" expr
fstring: FSTRING
subscript: NAME "[" expr "]"

// Appel de méthode / accès d'attribut : obj.methode(args)
attr_call: NAME "." (NAME | ARU | GHER | MDEL | KKES | SSEGEM | TTI | BDU | SDUKKEL | BEDDEL | ADER | ALI) ("(" [arguments] ")")?

call_expr: (NAME | ARU | SEQSI | ELDI | AMNAR | TEGHZI | SSENF | UTTU | AWAL | TABDART | AMEQQRAN | AMECTUH | RNU | FAKK | AMUR | AZAL | QERREB | AMAWAL) "(" [arguments] ")"

arguments: argument ("," argument)*
argument: NAME "=" expr -> keyword_arg
        | expr          -> pos_arg

// ============================================================
// TERMINAUX (TOKENS)
// ============================================================

// ── Mots-clés structurels (préfixe _ = ÉCARTÉS de l'arbre) ──
// Ces tokens servent uniquement à délimiter la syntaxe.
// Lark les consomme mais ne les met pas dans les enfants du
// nœud parent → les méthodes du Transformer ne les reçoivent pas.
//
// IMPORTANT : chaque mot-clé utilise une REGEX avec lookahead négatif
// (?![a-zA-Z0-9_\u00C0-\u02AF]) pour garantir qu'il ne matche QUE si
// suivi d'un caractère non-identificateur. Sans cela, "aru" matcherait
// même à l'intérieur de "aru_aselkim_negh_amensek" (car lark accorde
// la priorité aux terminaux avec priorité > 1, même sur un match plus
// court). La priorité 2 permet d'éviter l'ambiguïté avec NAME.
_MA_ULAC.2: /ma_ulac(?![a-zA-Z0-9_\u00C0-\u02AF])/
_MA.2:      /ma(?![a-zA-Z0-9_\u00C0-\u02AF])/
_YAL.2:     /yal(?![a-zA-Z0-9_\u00C0-\u02AF])/
_DEG.2:     /deg(?![a-zA-Z0-9_\u00C0-\u02AF])/
_SKUD.2:    /skud(?![a-zA-Z0-9_\u00C0-\u02AF])/
_BNU.2:     /bnu(?![a-zA-Z0-9_\u00C0-\u02AF])/
_ERRED.2:   /erred(?![a-zA-Z0-9_\u00C0-\u02AF])/
_AWID.2:    /awid(?![a-zA-Z0-9_\u00C0-\u02AF])/
_JERREB.2:  /jerreb(?![a-zA-Z0-9_\u00C0-\u02AF\u1E00-\u1EFF])/
_SLEK.2:    /slek(?![a-zA-Z0-9_\u00C0-\u02AF\u1E00-\u1EFF])/
_HBES.2:    /hbes(?![a-zA-Z0-9_\u00C0-\u02AF])/
_KEMMEL.2:  /kemmel(?![a-zA-Z0-9_\u00C0-\u02AF])/
_UMATA.2:  /umata(?![a-zA-Z0-9_\u00C0-\u02AF])/
_MA_YELLA.2: /ma_yella(?![a-zA-Z0-9_\u00C0-\u02AF\u1E00-\u1EFF])/

// ── Mots-clés de valeur / opérateur (CONSERVÉS dans l'arbre) ─
// Même technique de lookahead pour éviter les faux matchs.
IH.2: /[Ii]h(?![a-zA-Z0-9_\u00C0-\u02AF])/
ALA.2: /[Aa]la(?![a-zA-Z0-9_\u00C0-\u02AF])/
AKKED.2: /akked(?![a-zA-Z0-9_\u00C0-\u02AF])/
NEGH.2:  /negh(?![a-zA-Z0-9_\u00C0-\u02AF])/
MACCI.2: /macci(?![a-zA-Z0-9_\u00C0-\u02AF])/
ARU.2:   /aru(?![a-zA-Z0-9_\u00C0-\u02AF])/
SEQSI.2: /seqsi(?![a-zA-Z0-9_\u00C0-\u02AF])/
ELDI.2:  /eldi(?![a-zA-Z0-9_\u00C0-\u02AF])/
AMNAR.2: /amnar(?![a-zA-Z0-9_\u00C0-\u02AF])/
TEGHZI.2:/teghzi(?![a-zA-Z0-9_\u00C0-\u02AF])/
SSENF.2: /ssenf(?![a-zA-Z0-9_\u00C0-\u02AF])/
UTTU.2:  /uttu(?![a-zA-Z0-9_\u00C0-\u02AF])/
AWAL.2:   /awal(?![a-zA-Z0-9_\u00C0-\u02AF])/
TABDART.2:/tabdart(?![a-zA-Z0-9_\u00C0-\u02AF])/
AMEQQRAN.2:/ameqqran(?![a-zA-Z0-9_\u00C0-\u02AF])/
AMECTUH.2:/amectuh(?![a-zA-Z0-9_\u00C0-\u02AF])/
RNU.2:   /rnu(?![a-zA-Z0-9_\u00C0-\u02AF])/
FAKK.2:  /fakk(?![a-zA-Z0-9_\u00C0-\u02AF])/
GHER.2:  /gher(?![a-zA-Z0-9_\u00C0-\u02AF])/
MDEL.2:  /mdel(?![a-zA-Z0-9_\u00C0-\u02AF])/
KKES.2:  /kkes(?![a-zA-Z0-9_\u00C0-\u02AF])/
SSEGEM.2:/ssegem(?![a-zA-Z0-9_\u00C0-\u02AF])/
TTI.2:   /tti(?![a-zA-Z0-9_\u00C0-\u02AF])/
BDU.2:   /bdu(?![a-zA-Z0-9_\u00C0-\u02AF])/
SDUKKEL.2:/sdukkel(?![a-zA-Z0-9_\u00C0-\u02AF])/
BEDDEL.2:/beddel(?![a-zA-Z0-9_\u00C0-\u02AF])/
ADER.2:  /ader(?![a-zA-Z0-9_\u00C0-\u02AF])/
ALI.2:   /ali(?![a-zA-Z0-9_\u00C0-\u02AF])/
AMUR.2:  /amur(?![a-zA-Z0-9_\u00C0-\u02AF])/
AZAL.2:  /azal(?![a-zA-Z0-9_\u00C0-\u02AF])/
QERREB.2:/qerreb(?![a-zA-Z0-9_\u00C0-\u02AF])/
JERREB.2:/jerreb(?![a-zA-Z0-9_\u00C0-\u02AF])/
SLEK.2:  /slek(?![a-zA-Z0-9_\u00C0-\u02AF])/
HBES.2:  /hbes(?![a-zA-Z0-9_\u00C0-\u02AF])/
KEMMEL.2:/kemmel(?![a-zA-Z0-9_\u00C0-\u02AF])/
AMAWAL.2:/amawal(?![a-zA-Z0-9_\u00C0-\u02AF])/
TIDET.2: /tidet(?![a-zA-Z0-9_\u00C0-\u02AF])/

// ── Opérateurs arithmétiques (conservés) ────────────────────
// L'ordre compte : DOUBLESLASH (//) avant SLASH (/)
DOUBLESLASH: "//"
PLUS:        "+"
MINUS:       "-"
STAR:        "*"
SLASH:       "/"
PERCENT:     "%"

// ── Littéraux ────────────────────────────────────────────────
NUMBER: /\d+(\.\d+)?/
STRING: /"(\\.|[^"\\])*"/ | /'(\\.|[^'\\])*'/
FSTRING.3: /f"(\\.|[^"\\])*"/ | /f'(\\.|[^'\\])*'/

// ── Identificateurs ──────────────────────────────────────────
// Supporte aussi les caractères latins étendus (é, à, ç, ɛ, ɣ, etc.)
NAME: /[a-zA-Z_\u00C0-\u02AF\u1E00-\u1EFF\u03B5\u0395][a-zA-Z0-9_\u00C0-\u02AF\u1E00-\u1EFF\u03B5\u0395]*/

// ── Commentaires ─────────────────────────────────────────────
// ASTUCE : les commentaires sont INCLUS dans la définition de
// _NEWLINE (comme dans la grammaire Python officielle de lark).
// Cela évite que des lignes commentaires consécutives produisent
// plusieurs _NEWLINE que la règle `block` ne saurait pas gérer.
COMMENT: /#[^\n]*/

// ── Espaces internes (ignorés) ───────────────────────────────
// Les espaces en début de ligne sont gérés par l'Indenter.
%ignore /[^\S\n]+/

// ── Signaux d'indentation (gérés par KabyleIndenter) ─────────
// _NEWLINE absorbe : retours à la ligne + indentation + commentaires,
// ce qui permet aux lignes "commentaire pur" d'être transparentes.
_NEWLINE: (/\r?\n[\t ]*/ | COMMENT)+
%declare _INDENT _DEDENT
